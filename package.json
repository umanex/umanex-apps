{
  "private": true,
  "name": "umanex",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:rowtrack": "pnpm --filter rowtrack start",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules",
    "postinstall": "rm -rf apps/cashflow/node_modules/react node_modules/styled-jsx/node_modules/react && ln -s ../../../node_modules/next/node_modules/react apps/cashflow/node_modules/react && ln -s ../../next/node_modules/react node_modules/styled-jsx/node_modules/react"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "styled-jsx>react": "18.3.1"
    },
    "patchedDependencies": {
      "expo-router@6.0.23": "patches/expo-router@6.0.23.patch"
    }
  },
  "packageManager": "pnpm@9.0.0"
}
