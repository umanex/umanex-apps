{
  "name": "cashflow",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop cashflow",
    "pm2:restart": "pm2 restart cashflow",
    "pm2:logs": "pm2 logs cashflow",
    "pm2:status": "pm2 status",
    "pm2:rebuild": "next build && pm2 restart cashflow"
  },
  "dependencies": {
    "next": "^14",
    "react": "^18",
    "react-dom": "^18",
    "@umanex/ui": "workspace:*",
    "@umanex/tokens": "workspace:*",
    "@dnd-kit/core": "^6.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.0",
    "zustand": "^4.0.0",
    "immer": "^10.0.0",
    "date-fns": "^3.0.0",
    "clsx": "^2",
    "tailwind-merge": "^2"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@umanex/config": "workspace:*",
    "tailwindcss": "^3",
    "postcss": "^8",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "^14"
  }
}
