# Resend — transactionele mail voor het callback-formulier.
# Maak een gratis key aan op https://resend.com en zet die hier (lokaal in .env.local, niet committen).
RESEND_API_KEY=

# Afzender. Verifieer vyveyinterieur.be als sending-domain in Resend en gebruik bv.
# "Vyvey Website <website@vyveyinterieur.be>". Zonder geverifieerd domein: onboarding@resend.dev
CONTACT_FROM="Vyvey Website <onboarding@resend.dev>"

# Ontvanger van de callback-aanvragen.
CONTACT_TO=miekevyvey@skynet.be
