# Mock mode — gebruik fixtures i.p.v. echte API-calls
JOBRADAR_MOCK=1

# Pad naar de SQLite database (optioneel, default: .data/jobradar.db)
# JOBRADAR_DB_PATH=.data/jobradar.db

# Adzuna API (optioneel, alleen nodig als JOBRADAR_MOCK=0)
# ADZUNA_APP_ID=your_app_id
# ADZUNA_APP_KEY=your_app_key

# Setup:
# 1. cp .env.example .env.local
# 2. pnpm --filter jobradar dev   (start de app op http://localhost:3003)
